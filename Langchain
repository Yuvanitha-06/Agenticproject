from typing import TypedDict
from langgraph.graph import StateGraph, END
from langchain_core.messages import HumanMessage, AIMessage


def income_planner(state):
    user_message = state["messages"][-1].content

    # Extract number from input
    words = user_message.split()
    monthly_income = None

    for word in words:
        if word.isdigit():
            monthly_income = float(word)
            break

    if monthly_income is None:
        reply = "Please provide your monthly income as a number."
    else:
        annual = monthly_income * 12
        savings = monthly_income * 0.2
        investment = monthly_income * 0.1

        reply = (
            f"Annual Income: ₹{annual:,.2f}\n"
            f"Suggested Monthly Savings (20%): ₹{savings:,.2f}\n"
            f"Suggested Monthly Investment (10%): ₹{investment:,.2f}"
        )

    return {
        "messages": state["messages"] + [
            AIMessage(content=reply)
        ]
    }


class AgentState(TypedDict):
    messages: list



graph = StateGraph(AgentState)

graph.add_node("planner", income_planner)

graph.set_entry_point("planner")
graph.add_edge("planner", END)

app = graph.compile()



result = app.invoke({
    "messages": [HumanMessage(content="My monthly income is 50000")]
})

print(result["messages"][-1].content)
